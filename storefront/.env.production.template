# ─────────────────────────────────────────────────────────────
# Storefront production env (Cloudflare Workers via OpenNext).
#
# NEXT_PUBLIC_* values are BUILD-TIME: they are inlined into the bundle by
# `next build`. Set them as Build variables in the Cloudflare dashboard
# (Workers & Pages → project → Settings → Variables & Secrets → Build), or in
# your CI environment. A local copy at `.env.production` is used when you run
# the build yourself.
# ─────────────────────────────────────────────────────────────

# Public HTTPS URL of the Medusa backend (the Caddy domain on GCP).
NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://api.ccsunny.cn

# Publishable API key (Admin → Settings → Publishable API Keys → "Webshop").
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_change_me

# Public URL of this storefront (the Cloudflare domain).
NEXT_PUBLIC_BASE_URL=https://medusa.ccsunny.cn

# Default region (ISO-2 lowercase) when it can't be inferred from the request.
NEXT_PUBLIC_DEFAULT_REGION=us

# Payments (optional — fill in if using Medusa payments UI).
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

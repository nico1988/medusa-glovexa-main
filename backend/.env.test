# Env for the Jest integration test suites (loaded via loadEnv("test") in jest.config.js).
# The Medusa test runner (@medusajs/test-utils) builds its Postgres connection
# from DB_HOST / DB_USERNAME / DB_PASSWORD (NOT DATABASE_URL), then creates a
# throwaway per-run database, runs migrations, and drops it afterwards.
# These point at the local Docker "medusa-pg" (postgres:15, trust auth).
DB_HOST=localhost
DB_USERNAME=postgres
DB_PASSWORD=
DATABASE_URL=postgres://postgres@localhost:5432/medusa-test

# Cache + workflow engine are in-memory (see medusa-config.ts), so no Redis needed.

JWT_SECRET=supersecret
COOKIE_SECRET=supersecret
STORE_CORS=http://localhost:8000
ADMIN_CORS=http://localhost:9000,http://localhost:7001
AUTH_CORS=http://localhost:8000,http://localhost:9000
